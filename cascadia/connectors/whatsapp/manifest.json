{
  "id": "whatsapp-connector",
  "name": "WhatsApp Business Connector",
  "type": "connector",
  "version": "1.0.0",
  "description": "Send messages via WhatsApp Business Cloud API (Meta).",
  "author": "Zyrcon Labs",
  "price": 0,
  "tier_required": "lite",
  "port": 9001,
  "entry_point": "connector.py",
  "dependencies": [
    "nats-py"
  ],
  "install_hook": "install.sh",
  "uninstall_hook": "uninstall.sh",
  "category": "communication",
  "industries": [
    "all"
  ],
  "installed_by_default": false,
  "safe_to_uninstall": true,
  "auth_type": "bearer",
  "nats_subjects": [
    "cascadia.connectors.whatsapp-connector.>"
  ],
  "risk_level": "high",
  "permissions": [
    "send_message",
    "read_message"
  ],
  "requires_approval_for": [
    "message.send"
  ],
  "data_access": [
    "message_content",
    "phone_numbers"
  ],
  "writes_external_systems": true,
  "network_access": true,
  "setup_fields": [
    {
      "name": "api_key",
      "label": "WhatsApp Business API Key",
      "type": "secret",
      "required": true,
      "secret": true,
      "vault_key": "whatsapp:api_key",
      "simple_mode": true,
      "help_text": "From Meta Business Developer portal"
    },
    {
      "name": "phone_number_id",
      "label": "Phone Number ID",
      "type": "string",
      "required": true,
      "default": null,
      "simple_mode": true,
      "help_text": "WhatsApp phone number ID from Meta"
    },
    {
      "name": "approval_before_send",
      "label": "Require approval before sending messages",
      "type": "boolean",
      "required": false,
      "default": true,
      "simple_mode": true,
      "help_text": "Always approve before operators send WhatsApp",
      "requires_approval_if_enabled": ["whatsapp.send"]
    }
  ]
}

{
  "id": "slack-connector",
  "name": "Slack Connector",
  "type": "connector",
  "version": "1.0.0",
  "description": "Send messages and receive events from Slack channels and DMs via bot token or OAuth2.",
  "author": "Zyrcon Labs",
  "price": 0,
  "tier_required": "lite",
  "port": 9003,
  "entry_point": "connector.py",
  "dependencies": [
    "nats-py"
  ],
  "install_hook": "install.sh",
  "uninstall_hook": "uninstall.sh",
  "category": "communication",
  "industries": [
    "all"
  ],
  "installed_by_default": false,
  "safe_to_uninstall": true,
  "auth_type": "bearer",
  "nats_subjects": [
    "cascadia.connectors.slack-connector.>"
  ],
  "risk_level": "high",
  "permissions": [
    "send_message",
    "read_channel",
    "manage_webhooks"
  ],
  "requires_approval_for": [
    "message.send"
  ],
  "data_access": [
    "message_content",
    "channel_members"
  ],
  "writes_external_systems": true,
  "network_access": true,
  "setup_fields": [
    {
      "name": "bot_token",
      "label": "Slack Bot Token",
      "type": "secret",
      "required": true,
      "secret": true,
      "vault_key": "slack:bot_token",
      "simple_mode": true,
      "help_text": "From your Slack app settings"
    },
    {
      "name": "default_channel",
      "label": "Default Notification Channel",
      "type": "string",
      "required": false,
      "default": "#general",
      "simple_mode": true,
      "placeholder": "#zyrcon-alerts",
      "help_text": "Channel for operator notifications"
    },
    {
      "name": "approval_notifications",
      "label": "Send approval requests to Slack",
      "type": "boolean",
      "required": false,
      "default": false,
      "simple_mode": true,
      "help_text": "Receive approval requests in Slack"
    }
  ]
}

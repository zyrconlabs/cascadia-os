{
  "id": "modbus-connector",
  "name": "Modbus Connector",
  "type": "connector",
  "version": "1.0.0",
  "description": "Connects Cascadia to PLCs, VFDs, meters, and industrial equipment using Modbus TCP. All equipment writes require owner approval.",
  "author": "Zyrcon Labs",
  "price": 0,
  "tier_required": "pro",
  "port": 8306,
  "entry_point": "server.py",
  "dependencies": ["pymodbus"],
  "install_hook": "",
  "uninstall_hook": "",
  "category": "iot",
  "industries": ["manufacturing", "warehouse", "industrial"],
  "installed_by_default": false,
  "safe_to_uninstall": true,
  "auth_type": "none",
  "risk_level": "high",
  "permissions": ["modbus.read", "modbus.write"],
  "requires_approval_for": ["modbus.write_coil", "modbus.write_register"],
  "data_access": ["modbus_registers"],
  "writes_external_systems": true,
  "network_access": true,
  "capabilities": ["modbus.read", "modbus.write"],
  "required_dependencies": [],
  "requested_permissions": ["modbus.read"],
  "autonomy_level": "manual_only",
  "health_hook": "/api/health",
  "setup_fields": [
    {
      "name": "host",
      "label": "Modbus Device IP Address",
      "type": "string",
      "required": true,
      "default": null,
      "simple_mode": true,
      "placeholder": "192.168.1.100",
      "help_text": "IP address of Modbus TCP device or gateway"
    },
    {
      "name": "port",
      "label": "Modbus Port",
      "type": "number",
      "required": true,
      "default": 502,
      "min": 1,
      "max": 65535,
      "advanced_mode": true,
      "help_text": "Standard Modbus TCP port is 502"
    },
    {
      "name": "unit_id",
      "label": "Unit ID (Slave ID)",
      "type": "number",
      "required": true,
      "default": 1,
      "min": 1,
      "max": 247,
      "simple_mode": true,
      "help_text": "Modbus device unit/slave ID"
    },
    {
      "name": "approval_before_write",
      "label": "Require approval before writing to equipment",
      "type": "boolean",
      "required": false,
      "default": true,
      "simple_mode": true,
      "help_text": "ALL equipment writes require owner approval — cannot be disabled",
      "requires_approval_if_enabled": ["modbus.write_coil", "modbus.write_register"]
    },
    {
      "name": "timeout_seconds",
      "label": "Connection Timeout (seconds)",
      "type": "number",
      "required": false,
      "default": 3,
      "min": 1,
      "max": 30,
      "advanced_mode": true,
      "help_text": "How long to wait for device response"
    }
  ]
}

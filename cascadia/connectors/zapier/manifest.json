{
  "id": "zapier-connector",
  "name": "Zapier Inbound Connector",
  "type": "connector",
  "version": "1.0.0",
  "description": "Receive Zapier webhook triggers and send data to Zapier webhook actions.",
  "author": "Zyrcon",
  "price": 0,
  "tier_required": "lite",
  "port": 9030,
  "entry_point": "connector.py",
  "dependencies": [
    "nats-py"
  ],
  "install_hook": "install.sh",
  "uninstall_hook": "uninstall.sh",
